{
  "name": "@tsdraw/core",
  "version": "0.8.5",
  "description": "the core engine for tsdraw",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsdraw/tsdraw.git",
    "directory": "packages/tsdraw-core"
  },
  "homepage": "https://github.com/tsdraw/tsdraw/tree/main/packages/tsdraw-core",
  "bugs": {
    "url": "https://github.com/tsdraw/tsdraw/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run test"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "perfect-freehand": "^1.2.3"
  }
}
