{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@tsdraw/core": ["packages/tsdraw-core/src/index.ts"],
      "@tsdraw/core/*": ["packages/tsdraw-core/src/*"],
      "tsdraw": ["packages/tsdraw-react/src/index.ts"],
      "tsdraw/tsdraw.css": ["packages/tsdraw-react/src/styles/tsdraw.css"],
      "tsdraw/*": ["packages/tsdraw-react/src/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true
  },
  "exclude": ["node_modules", "dist", "**/dist"]
}
