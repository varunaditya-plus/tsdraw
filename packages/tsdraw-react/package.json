{
  "name": "@tsdraw/react",
  "version": "0.8.4",
  "description": "@tsdraw/react - React components and hooks for tsdraw",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsdraw/tsdraw.git",
    "directory": "packages/tsdraw-react"
  },
  "homepage": "https://github.com/tsdraw/tsdraw/tree/main/packages/tsdraw-react",
  "bugs": {
    "url": "https://github.com/tsdraw/tsdraw/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./tsdraw.css": "./dist/tsdraw.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup && cp src/styles/tsdraw.css dist/tsdraw.css",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.40.0",
    "@tsdraw/core": "latest"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
